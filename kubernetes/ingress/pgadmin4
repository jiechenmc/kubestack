apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: pgadmin4.local
spec:
  ingressClassName: traefik
  rules:
    - host: pgadmin.local
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: pgadmin4
                port:
                  number: 80
